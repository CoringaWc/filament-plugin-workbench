#!/usr/bin/env sh
# shellcheck shell=sh
set -eu

# ---------------------------------------------------------------------------
# filament-plugin-workbench — workbench CLI
# Bootstraps Filament plugin development environments (Docker only, no PHP/
# Composer needed on the host).
# ---------------------------------------------------------------------------

# ANSI colours (disabled when not a terminal)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    BOLD='\033[1m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' BOLD='' RESET=''
fi

_info()    { printf "${GREEN}[workbench]${RESET} %s\n" "$*"; }
_warn()    { printf "${YELLOW}[workbench] warn:${RESET} %s\n" "$*"; }
_error()   { printf "${RED}[workbench] error:${RESET} %s\n" "$*" >&2; }
_section() { printf "\n${BOLD}${BLUE}▶  %s${RESET}\n" "$*"; }

# ---------------------------------------------------------------------------
# Resolve the real path of this script (handles vendor/bin/ symlinks)
# ---------------------------------------------------------------------------
_real_path() {
    target="$1"
    cd "$(dirname "$target")"
    target="$(basename "$target")"
    while [ -L "$target" ]; do
        target="$(readlink "$target")"
        cd "$(dirname "$target")"
        target="$(basename "$target")"
    done
    printf "%s/%s" "$(pwd -P)" "$target"
}

SELF="$(_real_path "$0")"
WORKBENCH_BIN_DIR="$(dirname "$SELF")"
WORKBENCH_SOURCE="$(dirname "$WORKBENCH_BIN_DIR")"

# ---------------------------------------------------------------------------
# Find the plugin root: walk up from $PWD looking for a composer.json that
# is NOT the filament-plugin-workbench package itself.
# ---------------------------------------------------------------------------
_find_plugin_root() {
    dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/composer.json" ] && \
           ! grep -q '"name"[[:space:]]*:[[:space:]]*"coringawc/filament-plugin-workbench"' "$dir/composer.json" 2>/dev/null; then
            printf "%s" "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    _error "Could not find plugin root (no composer.json found in parent directories)."
    return 1
}

# ---------------------------------------------------------------------------
# Ensure providers are set in testbench.yaml from composer.json.
# Also generates APP_KEY if the placeholder is still present.
# ---------------------------------------------------------------------------
_ensure_providers() {
    testbench_yaml="$1"
    composer_json="$2"

    py_script="import json,re,sys,os,base64
with open(sys.argv[1]) as f:
    content=f.read()
with open(sys.argv[2]) as f:
    d=json.load(f)
providers=d.get('extra',{}).get('laravel',{}).get('providers',[])
messages=[]
sq=chr(39)
if providers:
    if '# - Vendor' in content:
        lines=chr(10).join('  - '+sq+p+sq for p in providers)
        block='providers:'+chr(10)+lines+chr(10)
        content=re.sub(r'providers:\n(\s*#[^\n]*\n)+',lambda m:block,content)
        messages.append('Providers set: '+', '.join(providers))
    else:
        added=[]
        missing_key=False
        for p in providers:
            pattern='(?m)^\\s+-\\s+['+sq+chr(34)+']?'+re.escape(p)
            if not re.search(pattern,content):
                idx=content.find('providers:'+chr(10))
                if idx>=0:
                    ins=idx+len('providers:'+chr(10))
                    content=content[:ins]+'  - '+sq+p+sq+chr(10)+content[ins:]
                    added.append(p)
                else:
                    missing_key=True
        if missing_key:
            messages.append('WARNING: providers: key not found in testbench.yaml — add the providers section manually.')
        if added:
            messages.append('Providers added: '+', '.join(added))
        elif not missing_key:
            messages.append('Providers already present.')
else:
    messages.append('No providers found in extra.laravel.providers — edit testbench.yaml manually.')
if 'REPLACE_WITH_GENERATED_KEY' in content:
    real_key='base64:'+base64.b64encode(os.urandom(32)).decode()
    content=content.replace(chr(34)+'base64:REPLACE_WITH_GENERATED_KEY'+chr(34),chr(34)+real_key+chr(34))
    messages.append('APP_KEY generated.')
with open(sys.argv[1],'w') as f:
    f.write(content)
if messages:
    print(chr(10).join(messages))"

    if command -v python3 > /dev/null 2>&1; then
        if result=$(python3 -c "$py_script" "$testbench_yaml" "$composer_json" 2>&1); then
            if [ -n "$result" ]; then
                printf "%s\n" "$result" | while IFS= read -r line; do
                    _info "$line"
                done
            fi
        else
            _warn "Failed to process testbench.yaml: $result"
        fi
    else
        _warn "python3 not found — using Docker to process testbench.yaml (one-time pull)"
        plugin_root="$(dirname "$composer_json")"
        yaml_rel="$(basename "$testbench_yaml")"
        if docker run --rm -v "${plugin_root}:/work" -w /work python:3-alpine \
                python3 -c "$py_script" "$yaml_rel" composer.json; then
            _info "Providers processed via Docker python."
        else
            _warn "Docker python fallback failed — check providers in testbench.yaml manually."
        fi
    fi
}

# ---------------------------------------------------------------------------
# Inject missing scripts into composer.json of the plugin.
# ---------------------------------------------------------------------------
_ensure_composer_scripts() {
    composer_json="$1"

    py_script="import json,sys
scripts={
    'bootstrap:workbench':'@php vendor/bin/testbench workbench:build --ansi',
    'serve':'@php vendor/bin/testbench serve --ansi',
    'fresh:workbench':'@php vendor/bin/testbench migrate:fresh --ansi --seed --seeder=WorkbenchSeeder'
}
with open(sys.argv[1]) as f:
    d=json.load(f)
s=d.setdefault('scripts',{})
added=[]
for name,cmd in scripts.items():
    if name not in s:
        s[name]=cmd
        added.append(name)
if added:
    with open(sys.argv[1],'w') as f:
        json.dump(d,f,indent=4,ensure_ascii=False)
        f.write(chr(10))
    print('Scripts added to composer.json: '+', '.join(added))
else:
    print('Composer scripts already present.')"

    if command -v python3 > /dev/null 2>&1; then
        if result=$(python3 -c "$py_script" "$composer_json" 2>&1); then
            [ -n "$result" ] && _info "$result"
        else
            _warn "Failed to update composer.json scripts: $result"
        fi
    else
        plugin_root="$(dirname "$composer_json")"
        if docker run --rm -v "${plugin_root}:/work" -w /work python:3-alpine \
                python3 -c "$py_script" composer.json; then
            _info "Composer scripts checked via Docker python."
        else
            _warn "Docker python fallback failed — add scripts to composer.json manually."
        fi
    fi
}

# ---------------------------------------------------------------------------
# Prompt yes/no. Returns 0 for yes, 1 for no.
# ---------------------------------------------------------------------------
_ask_yn() {
    printf "${YELLOW}  ?${RESET} %s [y/N] " "$1"
    read -r _answer
    case "$_answer" in
        [Yy]*) return 0 ;;
        *) return 1 ;;
    esac
}

# ---------------------------------------------------------------------------
# Copy a stub to dest. If dest exists, ask before overwriting (or force).
# Returns 0 if a new file was written, 1 if existing file was kept.
# ---------------------------------------------------------------------------
_copy_stub() {
    src="$1"
    dest="$2"
    label="$3"
    force="${4:-0}"

    if [ ! -f "$src" ]; then
        _error "Stub not found: $src"
        exit 1
    fi

    if [ -f "$dest" ]; then
        if [ "$force" = "1" ]; then
            cp "$src" "$dest"
            _info "$label overwritten (--force)."
            return 0
        fi
        _warn "$label already exists."
        if _ask_yn "Overwrite $label?"; then
            cp "$src" "$dest"
            _info "$label overwritten."
            return 0
        else
            _info "Keeping existing $label."
            return 1
        fi
    fi

    cp "$src" "$dest"
    _info "$label created."
    return 0
}

# ---------------------------------------------------------------------------
# Copy a stub to dest silently. If dest exists, skip without prompting.
# Returns 0 if a new file was written, 1 if existing file was skipped.
# ---------------------------------------------------------------------------
_copy_stub_silent() {
    src="$1"
    dest="$2"
    label="$3"

    if [ ! -f "$src" ]; then
        _error "Stub not found: $src"
        exit 1
    fi

    if [ -f "$dest" ]; then
        _info "$label already exists — skipping."
        return 1
    fi

    cp "$src" "$dest"
    _info "$label created."
    return 0
}

# ---------------------------------------------------------------------------
# Ensure Docker is available.
# ---------------------------------------------------------------------------
_require_docker() {
    if ! command -v docker > /dev/null 2>&1; then
        _error "Docker is not installed or not in PATH."
        _error "Install it from https://docs.docker.com/get-docker/"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Replace __WORKBENCH_DOCKER_CONTEXT__ placeholder in docker-compose.yml
# with the real relative path to docker/php (works for both submodule and
# Composer installations).
# ---------------------------------------------------------------------------
_fix_docker_context() {
    compose_file="$1"
    plugin_root="$2"

    docker_php_dir="$WORKBENCH_SOURCE/docker/php"
    if [ ! -d "$docker_php_dir" ]; then
        _error "Docker directory not found: $docker_php_dir"
        exit 1
    fi

    # Build a relative path from the plugin root to docker/php.
    # Use python3 if available; fallback to a simple string replacement.
    if command -v python3 > /dev/null 2>&1; then
        relative_path=$(python3 -c "import os,sys; print(os.path.relpath(sys.argv[1], sys.argv[2]))" "$docker_php_dir" "$plugin_root")
    elif command -v realpath > /dev/null 2>&1; then
        relative_path=$(realpath --relative-to="$plugin_root" "$docker_php_dir")
    else
        # Last resort: try common known paths
        if [ -d "$plugin_root/vendor/coringawc/filament-plugin-workbench/docker/php" ]; then
            relative_path="vendor/coringawc/filament-plugin-workbench/docker/php"
        elif [ -d "$plugin_root/packages/workbench/docker/php" ]; then
            relative_path="packages/workbench/docker/php"
        else
            _error "Cannot determine relative path to docker/php. Set build.context in docker-compose.yml manually."
            return 1
        fi
    fi

    sed -i "s|__WORKBENCH_DOCKER_CONTEXT__|./${relative_path}|" "$compose_file"
    _info "Docker build context set to: ./${relative_path}"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_up() {
    DETACH=0
    for arg in "$@"; do
        case "$arg" in
            -d|--detach) DETACH=1 ;;
            *) _warn "Unknown option for up: $arg" ;;
        esac
    done

    _require_docker

    PLUGIN_ROOT=$(_find_plugin_root)
    _info "Plugin root : $PLUGIN_ROOT"
    _info "Workbench   : $WORKBENCH_SOURCE"

    cd "$PLUGIN_ROOT"

    _section "Checking docker-compose.yml"
    if _copy_stub_silent \
        "$WORKBENCH_SOURCE/stubs/docker-compose.yml.stub" \
        "$PLUGIN_ROOT/docker-compose.yml" \
        "docker-compose.yml"; then
        _fix_docker_context "$PLUGIN_ROOT/docker-compose.yml" "$PLUGIN_ROOT"
    fi

    _section "Checking testbench.yaml"
    _copy_stub_silent \
        "$WORKBENCH_SOURCE/stubs/testbench.yaml.stub" \
        "$PLUGIN_ROOT/testbench.yaml" \
        "testbench.yaml" || true

    _section "Ensuring providers in testbench.yaml"
    _ensure_providers "$PLUGIN_ROOT/testbench.yaml" "$PLUGIN_ROOT/composer.json"

    _section "Checking composer.json scripts"
    _ensure_composer_scripts "$PLUGIN_ROOT/composer.json"

    _section "Starting container"
    docker compose up --build -d

    if [ "$DETACH" = "0" ]; then
        _info "Container started. Following logs (Ctrl+C to stop)..."
        docker compose logs -f php
    else
        _info "Container started in detached mode."
        _info "Use 'workbench logs' to follow logs."
    fi
}

cmd_down() {
    _require_docker
    PLUGIN_ROOT=$(_find_plugin_root)
    cd "$PLUGIN_ROOT"
    _section "Stopping container"
    docker compose down
    _info "Done."
}

cmd_fresh() {
    _require_docker
    PLUGIN_ROOT=$(_find_plugin_root)
    cd "$PLUGIN_ROOT"
    _section "Running migrate:fresh --seed inside container"
    docker compose exec php sh -c "composer run fresh:workbench"
}

cmd_logs() {
    _require_docker
    PLUGIN_ROOT=$(_find_plugin_root)
    cd "$PLUGIN_ROOT"
    docker compose logs -f php
}

cmd_shell() {
    _require_docker
    PLUGIN_ROOT=$(_find_plugin_root)
    cd "$PLUGIN_ROOT"
    _section "Opening shell inside container"
    docker compose exec php sh
}

cmd_install() {
    FORCE=0
    for arg in "$@"; do
        case "$arg" in
            -f|--force) FORCE=1 ;;
            *) _warn "Unknown option for install: $arg" ;;
        esac
    done

    PLUGIN_ROOT=$(_find_plugin_root)
    _info "Plugin root : $PLUGIN_ROOT"
    _info "Workbench   : $WORKBENCH_SOURCE"

    cd "$PLUGIN_ROOT"

    _section "Installing docker-compose.yml"
    if _copy_stub \
        "$WORKBENCH_SOURCE/stubs/docker-compose.yml.stub" \
        "$PLUGIN_ROOT/docker-compose.yml" \
        "docker-compose.yml" \
        "$FORCE"; then
        _fix_docker_context "$PLUGIN_ROOT/docker-compose.yml" "$PLUGIN_ROOT"
    fi

    _section "Installing testbench.yaml"
    _copy_stub \
        "$WORKBENCH_SOURCE/stubs/testbench.yaml.stub" \
        "$PLUGIN_ROOT/testbench.yaml" \
        "testbench.yaml" \
        "$FORCE" || true

    _section "Ensuring providers in testbench.yaml"
    _ensure_providers "$PLUGIN_ROOT/testbench.yaml" "$PLUGIN_ROOT/composer.json"

    _section "Checking composer.json scripts"
    _ensure_composer_scripts "$PLUGIN_ROOT/composer.json"

    _info "Install complete."
}

cmd_help() {
    printf "${BOLD}workbench${RESET} — Filament plugin development environment\n"
    printf "\n${BOLD}USAGE${RESET}\n"
    printf "  workbench <command> [options]\n"
    printf "\n${BOLD}COMMANDS${RESET}\n"
    printf "  ${GREEN}up${RESET} [-d]          Copy templates (if needed), ensure providers, inject composer scripts, start container\n"
    printf "                   ${BOLD}-d${RESET}  start in detached mode (no log tailing)\n"
    printf "  ${GREEN}install${RESET} [-f]      Copy templates, fill providers, inject composer scripts (no container start)\n"
    printf "                   ${BOLD}-f, --force${RESET}  overwrite existing files without prompting\n"
    printf "  ${GREEN}down${RESET}              Stop and remove container\n"
    printf "  ${GREEN}fresh${RESET}             Run migrate:fresh --seed inside the container\n"
    printf "  ${GREEN}logs${RESET}              Follow container logs in real time\n"
    printf "  ${GREEN}shell${RESET}             Open an interactive shell inside the container\n"
    printf "  ${GREEN}help${RESET}              Show this help message\n"
    printf "\n${BOLD}INSTALLATION — via git submodule (recommended, no Composer needed)${RESET}\n"
    printf "  git submodule add https://github.com/CoringaWc/filament-plugin-workbench.git packages/workbench\n"
    printf "  ./packages/workbench/bin/workbench up\n"
    printf "\n${BOLD}INSTALLATION — via Composer${RESET}\n"
    printf "  docker run --rm -v \"\$(pwd):/app\" -w /app composer:2 require --dev --ignore-platform-req=ext-intl coringawc/filament-plugin-workbench\n"
    printf "  ./vendor/bin/workbench up\n"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    up)              cmd_up "$@" ;;
    down)            cmd_down ;;
    fresh)           cmd_fresh ;;
    install)         cmd_install "$@" ;;
    logs)            cmd_logs ;;
    shell)           cmd_shell ;;
    help|--help|-h)  cmd_help ;;
    *)
        _error "Unknown command: $COMMAND"
        printf "Run 'workbench help' for usage.\n" >&2
        exit 1
        ;;
esac
